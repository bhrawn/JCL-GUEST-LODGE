{
  "name": "jcl-guest-lodge",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node src/index.js",
    "dev:client": "cd client && npm run dev",
    "seed": "cd server && node src/seed.js",
    "build": "cd client && npm install && npm run build"
  },
  "dependencies": {
    "express": "^4.21.1",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
